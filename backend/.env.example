# --- Backend environment variables (copy to .env for local runs) ---

# SQLAlchemy database URL. For Docker Compose the host is the "db" service.
DATABASE_URL=postgresql+psycopg://oms:oms_password@db:5432/oms

# Allowed CORS origins for the frontend. Use "*" for local dev, or a
# comma-separated list of exact origins in production, e.g.
# https://your-frontend.vercel.app
FRONTEND_ORIGIN=*

# Products with quantity below this value are reported as "low stock".
LOW_STOCK_THRESHOLD=10

# Seed demo data on first startup when the database is empty.
SEED_ON_STARTUP=true
