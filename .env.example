# --- Root environment for docker-compose (copy to .env) ---
# Credentials are NOT hardcoded in the compose file; they are read from here.

# PostgreSQL
POSTGRES_USER=oms
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=oms

# Backend
# For local dev "*" is fine. In production set to your frontend origin, e.g.
# https://your-frontend.vercel.app
FRONTEND_ORIGIN=*
LOW_STOCK_THRESHOLD=10
SEED_ON_STARTUP=true

# Frontend build arg — the API base URL the browser will call.
VITE_API_URL=http://localhost:8000
